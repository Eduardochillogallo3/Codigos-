#include <WiFi.h>
#include <ThingerESP32.h>
#include "DHT.h"

#define USERNAME "TU_USUARIO"
#define DEVICE_ID "TU_DEVICE"
#define DEVICE_CREDENTIAL "TU_CREDENCIAL"

#define SSID "TU_WIFI"
#define PASSWORD "TU_PASSWORD"

#define DHTPIN 4
#define DHTTYPE DHT11

ThingerESP32 thing(USERNAME, DEVICE_ID, DEVICE_CREDENTIAL);
DHT dht(DHTPIN, DHTTYPE);

void setup() {
Serial.begin(115200);
dht.begin();

thing.add_wifi(SSID, PASSWORD);

thing["Temperatura"] >> [](pson &out){
out = dht.readTemperature();
};

thing["Humedad"] >> [](pson &out){
out = dht.readHumidity();
};
}

void loop() {
thing.handle();
}